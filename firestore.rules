rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Personnel collection
    match /personnel/{personId} {
      // Allow any signed-in user to read (optional, user said "only admin should be able to work on common site")
      // But usually "working" means editing. Let's restrict read to admins too if they want full privacy.
      // Re-reading: "کاربر ادمین فقط بتونه روی سایت کار منه"
      // I'll allow read to signed in users, but write only to admins.
      allow read: if isSignedIn();
      
      allow create: if isAdmin() && isValidPersonnel(request.resource.data);
      allow update: if isAdmin() && isValidPersonnel(request.resource.data);
      allow delete: if isAdmin();
    }

    // Admins collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console or service account
    }

    function isValidPersonnel(data) {
      return data.keys().hasAll(['firstName', 'lastName', 'nationalId']) &&
             data.firstName is string && data.firstName.size() <= 100 &&
             data.lastName is string && data.lastName.size() <= 100 &&
             data.nationalId is string && data.nationalId.size() == 10;
    }
  }
}
